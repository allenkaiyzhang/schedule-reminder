# ============================================================
# Telegram Adapter
# ============================================================
TELEGRAM_BOT_TOKEN=

# ops-core HTTP endpoint.
OPS_CORE_BASE_URL=http://127.0.0.1:8080

# Must match ops-core OPS_API_TOKEN.
OPS_API_TOKEN=

# HTTP request timeout from Telegram adapter to ops-core.
OPS_API_TIMEOUT_SECONDS=15
