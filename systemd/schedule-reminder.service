[Unit]
Description=schedule-reminder
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/schedule-reminder
EnvironmentFile=/opt/schedule-reminder/.env
ExecStart=/opt/schedule-reminder/.venv/bin/uvicorn main:app --host 127.0.0.1 --port 8030
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
