# schedule-reminder service
HOST=127.0.0.1
PORT=8030
LOG_LEVEL=INFO
API_TOKEN=replace-with-strong-token
TIMEZONE=America/Los_Angeles
ENABLE_SCHEDULER=true
DISABLE_NOTIFICATIONS=false
DATA_DIR=/opt/schedule-reminder/data

# Telegram bot runtime. Required when ENABLE_SCHEDULER=true.
TELEGRAM_BOT_TOKEN=replace-me-if-needed
TELEGRAM_CHAT_ID=replace-me-if-needed
ALLOWED_USER_IDS=
WEBHOOK_URL=replace-me-if-needed

# Local storage and logs.
DATABASE_PATH=/opt/schedule-reminder/data/schedule.db
LOG_DIR=/opt/schedule-reminder/logs
SQLITE_BUSY_TIMEOUT_MS=5000

# Reminder behavior.
CHECK_INTERVAL_SECONDS=30
DEFAULT_REMIND_BEFORE_MINUTES=30,10,0
MORNING_SUMMARY_HOUR=8
EVENING_SUMMARY_HOUR=22

# AI parsing/summaries. Keep disabled for MVP unless configured.
AI_PROVIDER=disabled
AI_API_KEY=replace-with-ai-api-key
AI_BASE_URL=
AI_MODEL=
AI_TIMEOUT_SECONDS=20

# Optional project/notification integrations.
SSH_KEY_PATH=/opt/schedule-reminder/keys/control_key
SSH_TIMEOUT_SECONDS=10
DEFAULT_LOG_LINES=80
PROJECTS_CONFIG_PATH=/opt/schedule-reminder/projects.yaml
NOTIFICATION_PULL_ENABLED=false
NOTIFICATION_PULL_INTERVAL_SECONDS=120
NOTIFICATION_PULL_PROJECTS=api-report-agent
NOTIFICATION_PULL_LINES=50
TELEGRAM_NOTIFY_CHAT_ID=
