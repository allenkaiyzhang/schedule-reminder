# Sensitive environment only.
# Non-sensitive service settings live in registry.yaml.

# Required when registry.yaml scheduler.enabled=true and
# notifications.disable_sending=false.
TELEGRAM_BOT_TOKEN=replace-me-if-needed

# Treat chat/user identifiers as restricted deployment data.
TELEGRAM_NOTIFY_CHAT_ID=replace-me-if-needed
TELEGRAM_CHAT_ID=replace-me-if-needed
ALLOWED_USER_IDS=replace-me-if-needed

# Required only when registry.yaml ai.provider is enabled.
AI_API_KEY=replace-me-if-needed

# Required only if an authenticated HTTP/API integration is enabled.
API_TOKEN=replace-with-strong-token
OPS_API_TOKEN=replace-with-strong-token
WEBHOOK_URL=replace-me-if-needed
