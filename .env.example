TELEGRAM_BOT_TOKEN=
DEFAULT_TIMEZONE=Asia/Singapore
DATABASE_PATH=./data/schedule.db
CHECK_INTERVAL_SECONDS=30
DEFAULT_REMIND_BEFORE_MINUTES=30,10,0
ALLOWED_USER_IDS=

# AI 可设为 disabled/openai/deepseek/gemini
AI_PROVIDER=disabled
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=
