# ============================================================
# ops-core API
# ============================================================
# Required. Use the same value in tg_schedule_bot/.env.
OPS_API_TOKEN=

# API listen address.
OPS_API_HOST=0.0.0.0
OPS_API_PORT=8080

# Required for all ops-core requests.
# Empty means deny all users.
ALLOWED_USER_IDS=

# ============================================================
# SSH execution
# ============================================================
# Private key used by ops-core to connect to target hosts.
SSH_KEY_PATH=/opt/ops-core/keys/control_key

# SSH command timeout in seconds.
SSH_TIMEOUT_SECONDS=10

# Default /logs lines when caller does not pass lines.
DEFAULT_LOG_LINES=80

# YAML project registry.
PROJECTS_CONFIG_PATH=/opt/ops-core/projects.yaml

# ============================================================
# Local storage and logs
# ============================================================
DATABASE_PATH=/opt/ops-core/data/ops_core.db
LOG_DIR=/opt/ops-core/logs

# ============================================================
# Notification push
# ============================================================
# Required only when using /pull_notifications.
# ops-core sends Telegram messages itself after dedup.
TELEGRAM_BOT_TOKEN=

# Optional default chat id for scheduled or non-interactive pulls.
# Manual Telegram pulls pass X-Chat-Id from tg_schedule_bot.
TELEGRAM_NOTIFY_CHAT_ID=

# Number of notification archive lines to pull from scripts.notifications.
NOTIFICATION_PULL_LINES=50
